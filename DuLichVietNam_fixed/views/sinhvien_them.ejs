<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %></title>
</head>
<body class="bg-light">
<div class="container">
    <%- include('navbar') %>
    <div class="card mt-4">
        <div class="card-header bg-success text-white"><i class="bi bi-plus-circle"></i> <%= title %></div>
        <div class="card-body">
            <form method="post" action="/sinhvien/them" class="needs-validation" novalidate>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Mã địa điểm *</label>
                        <input type="text" class="form-control" name="maDiaDiem" required placeholder="VD: DD001">
                    </div>
                    <div class="col-md-8">
                        <label class="form-label">Tên địa điểm *</label>
                        <input type="text" class="form-control" name="tenDiaDiem" required placeholder="Tên địa điểm du lịch">
                    </div>
                    <div class="col-12">
                        <label class="form-label">Mô tả</label>
                        <textarea class="form-control" name="moTa" rows="3" placeholder="Mô tả ngắn về địa điểm..."></textarea>
                    </div>
                    <div class="col-md-8">
                        <label class="form-label">Địa chỉ</label>
                        <input type="text" class="form-control" name="diaChi" placeholder="Địa chỉ cụ thể">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Giờ mở cửa</label>
                        <input type="text" class="form-control" name="gioMoCua" placeholder="VD: 08:00 - 17:00">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Giá vé</label>
                        <input type="text" class="form-control" name="giaVe" placeholder="VD: Miễn phí / 50.000đ">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Hình ảnh (tên file)</label>
                        <input type="text" class="form-control" name="hinhAnh" placeholder="VD: diadiem.jpg">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Kinh độ (lng)</label>
                        <input type="number" step="0.0001" class="form-control" name="kinhDo" placeholder="VD: 105.8522">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Vĩ độ (lat)</label>
                        <input type="number" step="0.0001" class="form-control" name="viDo" placeholder="VD: 21.0285">
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Vùng miền *</label>
                        <select class="form-select" id="selVungMien" required>
                            <option value="">-- Chọn vùng miền --</option>
                            <% dsVungMien.forEach(v => { %>
                                <option value="<%= v._id %>"
                                    <%= (tinhThanh && tinhThanh.maLoaiHinh && tinhThanh.maLoaiHinh.maVungMien &&
                                        tinhThanh.maLoaiHinh.maVungMien.toString() == v._id.toString()) ? 'selected' : '' %>>
                                    <%= v.TenVungMien %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Loại hình du lịch *</label>
                        <select class="form-select" id="selLoaiHinh" name="maLoaiHinh" required>
                            <option value="">-- Chọn loại hình --</option>
                            <% dsLoaiHinh.forEach(lh => { %>
                                <option value="<%= lh._id %>"
                                    <%= (tinhThanh && tinhThanh.maLoaiHinh &&
                                        tinhThanh.maLoaiHinh._id.toString() == lh._id.toString()) ? 'selected' : '' %>>
                                    <%= lh.TenLoaiHinh %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Tỉnh / Thành phố *</label>
                        <select class="form-select" id="selTinhThanh2" name="maTinhThanh" required>
                            <option value="">-- Chọn tỉnh/thành --</option>
                            <% dsTinhThanh.forEach(tt => { %>
                                <option value="<%= tt._id %>"
                                    <%= (maTinhThanh && maTinhThanh == tt._id.toString()) ? 'selected' : '' %>>
                                    <%= tt.TenTinhThanh %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-success"><i class="bi bi-check-circle"></i> Lưu địa điểm</button>
                    <a href="/sinhvien" class="btn btn-secondary ms-2">Hủy</a>
                </div>
            </form>
        </div>
    </div>
    <%- include('footer') %>
    <%- include('javascript') %>
</div>
<script>
document.getElementById('selVungMien').addEventListener('change', function() {
    const maVungMien = this.value;
    const selLoaiHinh = document.getElementById('selLoaiHinh');
    const selTinhThanh = document.getElementById('selTinhThanh2');
    selLoaiHinh.innerHTML = '<option value="">-- Chọn loại hình --</option>';
    selTinhThanh.innerHTML = '<option value="">-- Chọn tỉnh/thành --</option>';
    if (!maVungMien) return;
    fetch('/sinhvien/api/loaihinh/' + maVungMien)
        .then(r => r.json())
        .then(data => {
            data.forEach(lh => selLoaiHinh.innerHTML += '<option value="' + lh._id + '">' + lh.TenLoaiHinh + '</option>');
        });
});

document.getElementById('selLoaiHinh').addEventListener('change', function() {
    const maLoaiHinh = this.value;
    const selTinhThanh = document.getElementById('selTinhThanh2');
    selTinhThanh.innerHTML = '<option value="">-- Chọn tỉnh/thành --</option>';
    if (!maLoaiHinh) return;
    fetch('/sinhvien/api/tinhthanh/' + maLoaiHinh)
        .then(r => r.json())
        .then(data => {
            data.forEach(tt => selTinhThanh.innerHTML += '<option value="' + tt._id + '">' + tt.TenTinhThanh + '</option>');
        });
});

(function () {
    'use strict';
    var forms = document.querySelectorAll('.needs-validation');
    Array.from(forms).forEach(function (form) {
        form.addEventListener('submit', function (event) {
            if (!form.checkValidity()) {
                event.preventDefault();
                event.stopPropagation();
            }
            form.classList.add('was-validated');
        }, false);
    });
})();
</script>
</body>
</html>
