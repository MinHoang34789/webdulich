<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://unpkg.com/maplibre-gl@3.5.2/dist/maplibre-gl.css" rel="stylesheet" />
    <style>
        body { background-color: #f0fdf4; }
        #map { height: 400px; width: 100%; border-radius: 12px; }
    </style>
    <title><%= title %> - Chi tiết</title>
</head>
<body>
<div class="container">
    <%- include('navbar') %>

    <div class="card mt-4">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="bi bi-geo-alt-fill"></i> <%= diaDiem.tenDiaDiem %></h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <table class="table table-borderless">
                        <tr><th>Mã địa điểm:</th><td><span class="badge bg-success"><%= diaDiem.maDiaDiem %></span></td></tr>
                        <tr><th>Địa chỉ:</th><td><%= diaDiem.diaChi || '—' %></td></tr>
                        <tr><th>Loại hình:</th><td><%= diaDiem.maTinhThanh?.maLoaiHinh?.TenLoaiHinh || diaDiem.maLoaiHinh?.TenLoaiHinh || '—' %></td></tr>
                        <tr><th>Tỉnh/Thành:</th><td><%= diaDiem.maTinhThanh?.TenTinhThanh || '—' %></td></tr>
                        <tr><th>Giờ mở cửa:</th><td><i class="bi bi-clock"></i> <%= diaDiem.gioMoCua || 'Cả ngày' %></td></tr>
                        <tr><th>Giá vé:</th><td><i class="bi bi-ticket-perforated text-success"></i> <strong class="text-success"><%= diaDiem.giaVe || 'Liên hệ' %></strong></td></tr>
                        <tr><th>Tọa độ:</th><td><small class="text-muted"><%= diaDiem.kinhDo %>, <%= diaDiem.viDo %></small></td></tr>
                    </table>
                    <div class="alert alert-light border">
                        <h6><i class="bi bi-info-circle"></i> Mô tả</h6>
                        <p class="mb-0"><%= diaDiem.moTa || 'Chưa có mô tả' %></p>
                    </div>
                </div>
                <div class="col-md-6">
                    <!-- Thời tiết -->
                    <div id="weather" class="alert alert-info mb-3">
                        <i class="bi bi-cloud-sun"></i> Đang tải thời tiết...
                    </div>
                    <!-- Bản đồ -->
                    <div id="map"></div>
                </div>
            </div>
            <a href="/sinhvien" class="btn btn-outline-secondary mt-3"><i class="bi bi-arrow-left"></i> Quay lại</a>
            <a href="/sinhvien/sua/<%= diaDiem._id %>" class="btn btn-warning mt-3 ms-2"><i class="bi bi-pencil"></i> Chỉnh sửa</a>
        </div>
    </div>

    <%- include('footer') %>
    <%- include('javascript') %>
</div>

<script src="https://unpkg.com/maplibre-gl@3.5.2/dist/maplibre-gl.js"></script>
<script>
    const lng = <%= diaDiem.kinhDo || 106 %>;
    const lat = <%= diaDiem.viDo || 16 %>;
    const map = new maplibregl.Map({
        container: 'map',
        style: 'https://api.maptiler.com/maps/streets/style.json?key=mztyHSEledNaviiGfWNU',
        center: [lng, lat], zoom: 13
    });
    new maplibregl.Marker({ color: '#2e7d32' })
        .setLngLat([lng, lat])
        .setPopup(new maplibregl.Popup().setHTML('<b><%= diaDiem.tenDiaDiem %></b><br><small><%= diaDiem.diaChi %></small>'))
        .addTo(map);
    map.addControl(new maplibregl.NavigationControl());

    fetch(`https://api.openweathermap.org/data/2.5/weather?lat=${lat}&lon=${lng}&appid=fb93b0f46bfb4d21f1bcaab7f9bd14c4&units=metric&lang=vi`)
        .then(r => r.json())
        .then(data => {
            document.getElementById('weather').innerHTML =
                `🌍 <strong>${data.name}</strong> | 🌤 ${data.weather[0].description} | 🌡 ${data.main.temp}°C | 💧 ${data.main.humidity}% | 💨 ${data.wind.speed} m/s`;
        })
        .catch(() => document.getElementById('weather').innerText = 'Không thể tải thời tiết.');
</script>
</body>
</html>
