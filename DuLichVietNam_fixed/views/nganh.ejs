<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <title><%= title %></title>
</head>
<body class="bg-light">
<div class="container">
  <%- include('navbar') %>
  <div class="mt-4">
    <h2><i class="bi bi-tags text-success"></i> Quản lý Loại hình du lịch</h2>
    <div class="d-flex justify-content-between align-items-center mb-3">
      <form method="get" class="d-flex gap-2">
        <select name="maVungMien" class="form-select" onchange="this.form.submit()">
          <option value="">-- Tất cả vùng miền --</option>
          <% dsVungMien.forEach(v => { %>
            <option value="<%= v._id %>"><%= v.TenVungMien %></option>
          <% }) %>
        </select>
        <a href="/nganh" class="btn btn-outline-secondary">Xóa lọc</a>
      </form>
      <a href="/nganh/them" class="btn btn-success"><i class="bi bi-plus-lg"></i> Thêm loại hình</a>
    </div>
    <div class="card">
      <table class="table table-hover mb-0">
        <thead class="table-success">
          <tr><th>#</th><th>Tên loại hình</th><th>Vùng miền</th><th>Hành động</th></tr>
        </thead>
        <tbody>
          <% if (!dsLoaiHinh || dsLoaiHinh.length === 0) { %>
            <tr><td colspan="4" class="text-center text-muted py-3">Chưa có loại hình du lịch nào</td></tr>
          <% } else { %>
            <% dsLoaiHinh.forEach((item, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td><strong><%= item.TenLoaiHinh %></strong></td>
                <td><span class="badge bg-success"><%= item.maVungMien?.TenVungMien || '—' %></span></td>
                <td>
                  <a href="/nganh/sua/<%= item._id %>" class="btn btn-warning btn-sm"><i class="bi bi-pencil"></i> Sửa</a>
                  <a href="/nganh/xoa/<%= item._id %>" class="btn btn-danger btn-sm"
                    onclick="return confirm('Xóa loại hình này?')"><i class="bi bi-trash"></i> Xóa</a>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <%- include('footer') %>
  <%- include('javascript') %>
</div>
</body>
</html>
