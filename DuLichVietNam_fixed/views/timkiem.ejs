<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <link href="https://unpkg.com/maplibre-gl@3.5.2/dist/maplibre-gl.css" rel="stylesheet" />
  <style>body{background-color:#f0fdf4;} #mapSearch{height:300px;border-radius:10px;}</style>
  <title><%= title %></title>
</head>
<body>
<div class="container">
  <%- include('navbar') %>
  <div class="mt-4">
    <h4><i class="bi bi-search text-success"></i> <%= title %></h4>

    <% if (!tukhoa) { %>
      <p class="text-muted">Nhập từ khóa vào thanh tìm kiếm ở trên để tìm địa điểm du lịch.</p>
    <% } else if (ketQua.length === 0) { %>
      <div class="alert alert-warning">Không tìm thấy địa điểm nào phù hợp với "<strong><%= tukhoa %></strong>".</div>
    <% } else { %>
      <p class="text-muted mb-3">Tìm thấy <strong><%= ketQua.length %></strong> địa điểm cho "<strong><%= tukhoa %></strong>"</p>

      <% if (ketQua.some(d => d.kinhDo && d.viDo)) { %>
      <div id="mapSearch" class="mb-4"></div>
      <% } %>

      <div class="row g-3">
        <% ketQua.forEach(dd => { %>
          <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm">
              <div class="card-body">
                <h6 class="fw-bold"><i class="bi bi-geo-alt-fill text-success"></i> <%= dd.tenDiaDiem %></h6>
                <p class="text-muted small mb-1"><i class="bi bi-map"></i> <%= dd.diaChi || '—' %></p>
                <p class="text-muted small mb-1"><i class="bi bi-tags"></i> <%= dd.maLoaiHinh?.TenLoaiHinh || '—' %></p>
                <p class="small text-success fw-bold"><i class="bi bi-ticket-perforated"></i> <%= dd.giaVe || '—' %></p>
                <a href="/sinhvien/chitiet/<%= dd._id %>" class="btn btn-outline-success btn-sm w-100">
                  <i class="bi bi-eye"></i> Xem chi tiết
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
  <%- include('footer') %>
  <%- include('javascript') %>
</div>
<% if (ketQua && ketQua.some(d => d.kinhDo && d.viDo)) { %>
<script src="https://unpkg.com/maplibre-gl@3.5.2/dist/maplibre-gl.js"></script>
<script>
const diem = <%- JSON.stringify(ketQua.filter(d => d.kinhDo && d.viDo).map(d => ({ ten: d.tenDiaDiem, lng: d.kinhDo, lat: d.viDo, id: d._id }))) %>;
const map = new maplibregl.Map({
  container: 'mapSearch',
  style: 'https://api.maptiler.com/maps/streets/style.json?key=mztyHSEledNaviiGfWNU',
  center: [diem[0].lng, diem[0].lat], zoom: 8
});
map.addControl(new maplibregl.NavigationControl());
diem.forEach(d => {
  new maplibregl.Marker({ color: '#2e7d32' })
    .setLngLat([d.lng, d.lat])
    .setPopup(new maplibregl.Popup().setHTML(`<b>${d.ten}</b><br><a href="/sinhvien/chitiet/${d.id}">Xem chi tiết</a>`))
    .addTo(map);
});
</script>
<% } %>
</body>
</html>
