<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <title><%= title %></title>
</head>
<body class="bg-light">
<div class="container">
  <%- include('navbar') %>
  <div class="mt-4">
    <h2><i class="bi bi-pin-map text-success"></i> Quản lý Tỉnh / Thành phố</h2>

    <div class="card mb-3 p-3">
      <form id="formLoc" method="get" action="/lop" class="row g-2 align-items-end">
        <div class="col-auto">
          <label class="form-label small fw-bold">Vùng miền</label>
          <select class="form-select" name="maVungMien" id="selVungMien" onchange="loadLoaiHinh(this.value)">
            <option value="">-- Tất cả --</option>
            <% dsVungMien.forEach(v => { %>
              <option value="<%= v._id %>" <%= (maVungMienDaChon == v._id.toString()) ? 'selected' : '' %>>
                <%= v.TenVungMien %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="col-auto">
          <label class="form-label small fw-bold">Loại hình du lịch</label>
          <select class="form-select" name="maLoaiHinh" id="selLoaiHinh" onchange="document.getElementById('formLoc').submit()">
            <option value="">-- Tất cả --</option>
            <% dsLoaiHinh.forEach(lh => { %>
              <option value="<%= lh._id %>" <%= (maLoaiHinhDaChon == lh._id.toString()) ? 'selected' : '' %>>
                <%= lh.TenLoaiHinh %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="col-auto">
          <a href="/lop" class="btn btn-outline-secondary">Xóa lọc</a>
        </div>
        <div class="col-auto ms-auto">
          <a href="/lop/them" class="btn btn-success"><i class="bi bi-plus-lg"></i> Thêm tỉnh/thành</a>
        </div>
      </form>
    </div>

    <div class="card">
      <table class="table table-hover mb-0">
        <thead class="table-success">
          <tr><th>#</th><th>Tên Tỉnh / Thành phố</th><th>Loại hình du lịch</th><th>Hành động</th></tr>
        </thead>
        <tbody>
          <% if (!dsTinhThanh || dsTinhThanh.length === 0) { %>
            <tr><td colspan="4" class="text-center text-muted py-3">Chưa có tỉnh/thành nào (hãy chọn vùng miền và loại hình để lọc)</td></tr>
          <% } else { %>
            <% dsTinhThanh.forEach((tt, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td><strong><%= tt.TenTinhThanh %></strong></td>
                <td><span class="badge bg-success"><%= tt.maLoaiHinh?.TenLoaiHinh || '—' %></span></td>
                <td>
                  <a href="/lop/sua/<%= tt._id %>" class="btn btn-warning btn-sm"><i class="bi bi-pencil"></i> Sửa</a>
                  <a href="/lop/xoa/<%= tt._id %>" class="btn btn-danger btn-sm"
                    onclick="return confirm('Xóa tỉnh/thành này?')"><i class="bi bi-trash"></i> Xóa</a>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <%- include('footer') %>
  <%- include('javascript') %>
</div>
<script>
function loadLoaiHinh(maVungMien) {
  if (!maVungMien) return;
  fetch('/lop/api/loaihinh/' + maVungMien)
    .then(r => r.json())
    .then(data => {
      const sel = document.getElementById('selLoaiHinh');
      sel.innerHTML = '<option value="">-- Tất cả --</option>';
      data.forEach(lh => sel.innerHTML += `<option value="${lh._id}">${lh.TenLoaiHinh}</option>`);
    });
}
</script>
</body>
</html>
