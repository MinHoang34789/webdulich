<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" /><title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
</head>
<body class="bg-light">
<div class="container mt-4">
  <%- include('navbar') %>
  <div class="card mt-3">
    <div class="card-header bg-success text-white"><i class="bi bi-plus-circle"></i> Thêm Tỉnh / Thành phố</div>
    <div class="card-body">
      <form method="post" action="/lop/them" class="needs-validation" novalidate>
        <div class="mb-3">
          <label class="form-label">Tên tỉnh / thành phố *</label>
          <input type="text" class="form-control" name="TenTinhThanh" required placeholder="VD: Đà Nẵng" />
        </div>
        <div class="mb-3">
          <label class="form-label">Vùng miền</label>
          <select class="form-select" id="selVungMien" onchange="loadLoaiHinh(this.value)">
            <option value="">-- Chọn vùng miền trước --</option>
            <% dsVungMien.forEach(v => { %>
              <option value="<%= v._id %>"><%= v.TenVungMien %></option>
            <% }) %>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label">Loại hình du lịch *</label>
          <select class="form-select" id="selLoaiHinh" name="maLoaiHinh" required>
            <option value="">-- Chọn loại hình --</option>
            <% if (dsLoaiHinh) { dsLoaiHinh.forEach(lh => { %>
              <option value="<%= lh._id %>"><%= lh.TenLoaiHinh %></option>
            <% }) } %>
          </select>
        </div>
        <button type="submit" class="btn btn-success"><i class="bi bi-check-circle"></i> Lưu</button>
        <a href="/lop" class="btn btn-secondary ms-2">Quay lại</a>
      </form>
    </div>
  </div>
  <%- include('footer') %>
  <%- include('javascript') %>
</div>
<script>
function loadLoaiHinh(maVungMien) {
  fetch('/lop/api/loaihinh/' + maVungMien)
    .then(r => r.json())
    .then(data => {
      const sel = document.getElementById('selLoaiHinh');
      sel.innerHTML = '<option value="">-- Chọn loại hình --</option>';
      data.forEach(lh => sel.innerHTML += `<option value="${lh._id}">${lh.TenLoaiHinh}</option>`);
    });
}
</script>
</body>
</html>
